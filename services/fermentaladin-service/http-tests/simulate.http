# ---------------------------------------------------------------------------
# Error cases
# ---------------------------------------------------------------------------

###
# @name error_missing_model_in_phase1
# Expects HTTP 422: "Model" is required for phase 1.
POST {{baseUrl}}/simulate/df
Content-Type: application/json

[
  {
    "Phase": 1,
    "Q_Air": 80.0,
    "Bolus_C": 100.0,
    "Feed_C": 0.0,
    "Bolus_N": 5.0,
    "Drehzahl": 500.0,
    "Druck": 0.0,
    "Dauer": 10.0,
    "V_L": 100.0,
    "T": 30.0,
    "pH": 6.5,
    "DO": 100.0,
    "c_x0": 0.1
  }
]

###
# @name error_missing_DO_in_phase1
