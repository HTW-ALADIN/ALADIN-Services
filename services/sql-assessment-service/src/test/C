SELECT "p1"."senior_professor_id" FROM "public"."professor_benefits" RIGHT JOIN "public"."professors" AS "p1" ON professor_benefits.professor_id = p1.professor_id FULL JOIN "public"."professors" AS "p2" ON p1.senior_professor_id = p2.professor_id RIGHT JOIN "public"."faculties" ON p2.faculty_id = faculties.faculty_id WHERE "professor_benefits"."benefit_id" BETWEEN 2 AND 3 GROUP BY "p1"."senior_professor_id" HAVING COUNT("p2"."name") <= '40' ORDER BY "p1"."senior_professor_id" DESC