{
  "openapi": "3.1.0",
  "info": {
    "title": "Noise Generation Service",
    "description": "Deterministic procedural noise API for random scalar fields and contour-style plots. Designed as a REST and CLI wrapper around an embeddable noise generator.",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/noise/grid": {
      "post": {
        "tags": [
          "Noise"
        ],
        "summary": "Generate a deterministic procedural noise grid",
        "operationId": "noise_grid_noise_grid_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoiseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GridResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/noise/contour.svg": {
      "post": {
        "tags": [
          "Noise"
        ],
        "summary": "Generate a contour-style SVG plot from a deterministic procedural noise grid",
        "operationId": "contour_svg_noise_contour_svg_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoiseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "image/svg+xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GridResponse": {
        "properties": {
          "width": {
            "type": "integer",
            "title": "Width"
          },
          "height": {
            "type": "integer",
            "title": "Height"
          },
          "seed": {
            "type": "integer",
            "title": "Seed"
          },
          "min": {
            "type": "number",
            "title": "Min"
          },
          "max": {
            "type": "number",
            "title": "Max"
          },
          "values": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "type": "array",
            "title": "Values",
            "description": "Row-major normalized scalar values in the range 0..1."
          }
        },
        "type": "object",
        "required": [
          "width",
          "height",
          "seed",
          "min",
          "max",
          "values"
        ],
        "title": "GridResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "NoiseRequest": {
        "properties": {
          "width": {
            "type": "integer",
            "maximum": 512.0,
            "minimum": 2.0,
            "title": "Width",
            "description": "Grid width in cells.",
            "default": 128
          },
          "height": {
            "type": "integer",
            "maximum": 512.0,
            "minimum": 2.0,
            "title": "Height",
            "description": "Grid height in cells.",
            "default": 128
          },
          "seed": {
            "type": "integer",
            "maximum": 2147483647.0,
            "minimum": 0.0,
            "title": "Seed",
            "description": "Deterministic random seed.",
            "default": 0
          },
          "scale": {
            "type": "number",
            "maximum": 10000.0,
            "exclusiveMinimum": 0.0,
            "title": "Scale",
            "description": "Spatial scale; larger values zoom out.",
            "default": 32.0
          },
          "octaves": {
            "type": "integer",
            "maximum": 10.0,
            "minimum": 1.0,
            "title": "Octaves",
            "description": "Number of fractal noise octaves.",
            "default": 4
          },
          "persistence": {
            "type": "number",
            "maximum": 1.0,
            "exclusiveMinimum": 0.0,
            "title": "Persistence",
            "description": "Amplitude multiplier per octave.",
            "default": 0.5
          },
          "lacunarity": {
            "type": "number",
            "maximum": 4.0,
            "minimum": 1.0,
            "title": "Lacunarity",
            "description": "Frequency multiplier per octave.",
            "default": 2.0
          },
          "levels": {
            "type": "integer",
            "maximum": 32.0,
            "minimum": 2.0,
            "title": "Levels",
            "description": "Number of color bands in SVG contour output.",
            "default": 10
          },
          "samplePoints": {
            "type": "integer",
            "maximum": 128.0,
            "minimum": 0.0,
            "title": "Samplepoints",
            "description": "Optional number of deterministic sample points to overlay in SVG output.",
            "default": 0
          }
        },
        "type": "object",
        "title": "NoiseRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}